# =============================================
# Estiellart Portfolio — .gitignore
# =============================================

# ── Datos privados de la artista ─────────────
# Información extraída del sitio viejo (precios, ToS, referencias internas)
# No debe subirse porque contiene datos sensibles de negocio
estiellart_data/

# ── Imágenes de auditoría / capturas de QA ───
# Son artefactos de trabajo interno, no forman parte del producto final
audit-*.png
audit-*.jpg

# ── Herramientas de agente / MCP ─────────────
# Carpetas generadas automáticamente por Playwright MCP y herramientas de AI
.playwright-mcp/
.atl/

# ── Stitch (design tool output) ──────────────
# Archivos generados por la herramienta de diseño, no código fuente manual
stitch/

# ── Página antigua de la tienda (reemplazada) ─
# tienda.html fue reemplazada por comisiones.html
tienda.html

# ── Sistema Operativo ─────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editores ─────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Imágenes (cuando se agreguen) ────────────
# Las imágenes de la artista NO se suben al repo público.
# Usar un CDN o subdirectorio privado separado.
# Descomenta si creas la carpeta:
# images/
# assets/img/

# ── Node (por si se agrega tooling futuro) ────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.*.local

# ── Logs varios ──────────────────────────────
*.log
